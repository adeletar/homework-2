@app.route("/summary/monthly")
def summary_monthly():
    df["applied_date"] = pd.to_datetime(df["applied_date"], errors="coerce")
    result = df.groupby(["applied_year", "applied_month"]).agg(
        total_permits=("permit_number", "count"),
        total_job_valuation=("total_job_valuation", "sum"),
    ).reset_index()
 
    result["total_job_valuation"] = result["total_job_valuation"].round(2)
    result = result.sort_values(["applied_year", "applied_month"])
 
    csv_data = result.to_csv(index=False)
    filename = f"plan_review_monthly_{date.today().isoformat()}.csv"
    return Response(
        csv_data,
        mimetype="text/csv",
        headers={"Content-Disposition": f"attachment; filename={filename}"}
    )
 
if __name__ == "__main__":
    app.run(debug=True, port=5000)
