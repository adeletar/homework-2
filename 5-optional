api.py - Phase 5 (Optional): Data API
Endpoints:
  GET /summary              - Summary by council district and work class
  GET /summary/district     - Summary by council district only
  GET /summary/workclass    - Summary by work class only
  GET /summary/monthly      - Monthly permit counts
 
Usage:
  pip install flask pandas
  python api.py
  Then visit http://localhost:5000/summary in your browser to download the CSV
"""
 
from flask import Flask, Response
import pandas as pd
from datetime import date
 
app = Flask(__name__)
 
# Load data once when the app starts
print("Loading data...")
df = pd.read_csv("plan_review_transformed.csv", low_memory=False)
print(f"Loaded {len(df)} records")
 
@app.route("/")
def index():
    return """
    <h2>Austin Plan Review Cases API</h2>
    <p>Available endpoints:</p>
    <ul>
        <li><a href="/summary">/summary</a> - Full summary by district and work class</li>
        <li><a href="/summary/district">/summary/district</a> - Summary by council district</li>
        <li><a href="/summary/workclass">/summary/workclass</a> - Summary by work class</li>
        <li><a href="/summary/monthly">/summary/monthly</a> - Monthly permit counts</li>
    </ul>
    """
 
@app.route("/summary")
def summary():
    result = df.groupby(["council_district", "work_class"]).agg(
        total_permits=("permit_number", "count"),
        total_job_valuation=("total_job_valuation", "sum"),
        avg_job_valuation=("total_job_valuation", "mean"),
        total_units=("number_of_units", "sum")
    ).reset_index()
 
    result["total_job_valuation"] = result["total_job_valuation"].round(2)
    result["avg_job_valuation"]   = result["avg_job_valuation"].round(2)
 
    csv_data = result.to_csv(index=False)
    filename = f"plan_review_summary_{date.today().isoformat()}.csv"
    return Response(
        csv_data,
        mimetype="text/csv",
        headers={"Content-Disposition": f"attachment; filename={filename}"}
    )
 
